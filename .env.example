# ── LLM ──────────────────────────────────────────
# Get free API key from console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── LangSmith Tracing ─────────────────────────────
# Get free API key from smith.langchain.com
# Set to false to disable tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=atliq-rag

# ── Qdrant ────────────────────────────────────────
# Leave as default for local disk-based storage
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=atliq_docs

# ── JWT Auth ──────────────────────────────────────
# Change this to a long random string in production
JWT_SECRET_KEY=your_super_secret_key_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=8

# ── Embeddings ────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── App ───────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO